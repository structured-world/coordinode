kw_analyzer   = @{ ^"analyzer" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_unique     = @{ ^"unique" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_sparse     = @{ ^"sparse" ~ !(ASCII_ALPHANUMERIC | "_") }
