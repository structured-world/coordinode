// OpenCypher PEG grammar for CoordiNode (read + write operations)
// Read: MATCH, OPTIONAL MATCH, WHERE, RETURN, WITH, UNWIND,
//       ORDER BY, SKIP, LIMIT, AS OF TIMESTAMP
// Write: CREATE, MERGE, DELETE, DETACH DELETE, DETACH DOCUMENT, ATTACH DOCUMENT, SET, REMOVE
// Extensions: UPSERT MATCH, vector functions, parameters

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT    = _{ "//" ~ (!"\n" ~ ANY)* | "/*" ~ (!"*/" ~ ANY)* ~ "*/" }

// --- Top-level ---

query = { SOI ~ clause+ ~ union_branch* ~ EOI }

// UNION / UNION ALL: each branch is its own clause sequence. `clause+` above
// stops at the UNION keyword (no clause alternative matches it), so the
// branches are picked up here.
union_branch = { kw_union ~ kw_all? ~ clause+ }

clause = {
    optional_match_clause
  | match_clause
  | foreach_clause
  | where_clause
  | return_clause
  | with_clause
  | unwind_clause
  | as_of_timestamp_clause
  | call_subquery_clause
  | call_clause
  | alter_label_clause
  | create_encrypted_index_clause
  | create_text_index_clause
  | create_vector_index_clause
  | create_index_clause
  | create_edge_type_clause
  | create_node_type_clause
  | create_trigger_clause
  | drop_trigger_clause
  | show_triggers_clause
  | alter_trigger_clause
  | create_clause
  | merge_all_clause
  | merge_nodes_clause
  | merge_clause
  | upsert_clause
  | detach_document_clause
  | attach_document_clause
  | detach_delete_clause
  | drop_encrypted_index_clause
  | drop_text_index_clause
  | drop_vector_index_clause
  | drop_index_clause
  | delete_clause
  | set_clause
  | remove_clause
}

// --- MATCH ---

match_clause = { kw_match ~ match_pattern_list ~ where_inline? }
optional_match_clause = { kw_optional ~ kw_match ~ match_pattern_list ~ where_inline? }

// MATCH-only pattern forms: an optional named-path assignment (`p = ...`)
// and the `shortestPath(...)` wrapper. Kept separate from `pattern` so the
// CREATE / MERGE / WHERE-predicate paths that consume `pattern` are unchanged.
match_pattern_list = { match_pattern ~ ("," ~ match_pattern)* }
match_pattern = { path_assign? ~ (shortest_path_pattern | pattern) }
path_assign = { variable ~ "=" }
shortest_path_pattern = { kw_shortestpath ~ "(" ~ pattern ~ ")" }

where_inline = { kw_where ~ expression }
where_clause = { kw_where ~ expression }

pattern_list = { pattern ~ ("," ~ pattern)* }
pattern = { pattern_element+ }

pattern_element = { node_pattern ~ (relationship_pattern ~ node_pattern)* }

node_pattern = {
    "(" ~ variable? ~ label_list? ~ property_map? ~ ")"
}

label_list = { (":" ~ identifier)+ }

relationship_pattern = {
    left_arrow ~ "[" ~ rel_detail ~ "]" ~ right_arrow
  | left_arrow ~ "[" ~ rel_detail ~ "]" ~ dash
  | dash ~ "[" ~ rel_detail ~ "]" ~ right_arrow
  | dash ~ "[" ~ rel_detail ~ "]" ~ dash
  | left_arrow ~ right_arrow
  | left_arrow ~ dash
  | dash ~ right_arrow
  | dash ~ dash
}

left_arrow  = { "<-" | "-" }
right_arrow = { "->" | "-" }
dash        = { "-" }

rel_detail = { variable? ~ rel_type_list? ~ length_spec? ~ property_map? }

rel_type_list = { ":" ~ identifier ~ ("|" ~ ":"? ~ identifier)* }

length_spec = { "*" ~ length_range? }
length_range = {
    integer_literal ~ ".." ~ integer_literal
  | integer_literal ~ ".."
  | ".." ~ integer_literal
  | integer_literal
}

// --- RETURN ---
// ORDER BY, SKIP, LIMIT are part of the return body per OpenCypher spec.

return_clause = { kw_return ~ distinct_kw? ~ return_items ~ order_by_part? ~ skip_part? ~ limit_part? }
return_items  = { return_item ~ ("," ~ return_item)* }
return_item   = { star | expression ~ alias? }
alias         = { kw_as ~ identifier }
distinct_kw   = { kw_distinct }
star          = { "*" }

order_by_part = { kw_order ~ kw_by ~ sort_item ~ ("," ~ sort_item)* }
sort_item     = { expression ~ sort_direction? }
sort_direction = { kw_desc | kw_descending | kw_asc | kw_ascending }

skip_part  = { kw_skip ~ expression }
limit_part = { kw_limit ~ expression }

// --- WITH ---

with_clause = { kw_with ~ distinct_kw? ~ return_items ~ order_by_part? ~ skip_part? ~ limit_part? ~ where_inline? }

// --- UNWIND ---

unwind_clause = { kw_unwind ~ expression ~ kw_as ~ identifier }

// --- AS OF TIMESTAMP ---

as_of_timestamp_clause = { kw_as ~ kw_of ~ kw_timestamp ~ expression }

// --- CALL (procedure invocation) ---
// CALL db.advisor.suggestions() YIELD id, severity, kind, ...

// CALL { <subquery> } — execute an inner query per outer row. A leading
// `WITH <vars>` inside the braces imports outer-scope variables (correlated);
// without it the subquery is uncorrelated. `OPTIONAL CALL { ... }` keeps the
// outer row (with NULLs) when the subquery returns no rows. Tried before
// `call_clause`: the `{` after CALL disambiguates from `CALL proc(...)`.
call_subquery_clause = { kw_optional? ~ kw_call ~ "{" ~ clause+ ~ "}" }

call_clause = { kw_call ~ procedure_name ~ "(" ~ procedure_args? ~ ")" ~ yield_clause? }
procedure_name = { identifier ~ ("." ~ identifier)* }
procedure_args = { expression ~ ("," ~ expression)* }
yield_clause = { kw_yield ~ yield_items }
yield_items = { yield_item ~ ("," ~ yield_item)* }
yield_item = { identifier ~ alias? }

// --- CREATE ---

// --- ALTER LABEL ---

alter_label_clause = { kw_alter ~ kw_label ~ identifier ~ kw_set ~ kw_schema ~ schema_mode }
schema_mode = @{ ^"strict" | ^"validated" | ^"flexible" }

// --- CREATE/DROP TEXT INDEX ---

// Simple syntax:  CREATE TEXT INDEX idx ON :Label(prop) [LANGUAGE "en"]
// Extended syntax: CREATE TEXT INDEX idx ON :Label {
//   title: { analyzer: "english" },
//   body:  { analyzer: "auto_detect" }
// } [DEFAULT LANGUAGE "english"] [LANGUAGE OVERRIDE "lang"]
create_text_index_clause = {
    kw_create ~ kw_text ~ kw_index ~ identifier ~ kw_on ~ ":" ~ identifier
    ~ (text_index_multi_field | text_index_single_field)
    ~ text_index_default_language?
    ~ text_index_language_override?
}

// Single-field: ON :Label(property) [LANGUAGE "en"]
text_index_single_field = { "(" ~ identifier ~ ")" ~ text_index_language? }
text_index_language = { kw_language ~ string_literal }

// Multi-field: { field: { analyzer: "..." }, ... }
text_index_multi_field = { "{" ~ text_index_field_def ~ ("," ~ text_index_field_def)* ~ ","? ~ "}" }
text_index_field_def   = { identifier ~ ":" ~ "{" ~ text_field_option ~ ("," ~ text_field_option)* ~ ","? ~ "}" }
text_field_option      = { text_field_analyzer }
text_field_analyzer    = { kw_analyzer ~ ":" ~ string_literal }

// Index-level modifiers
text_index_default_language  = { kw_default ~ kw_language ~ string_literal }
text_index_language_override = { kw_language ~ kw_override ~ string_literal }

// DROP TEXT INDEX idx_name
drop_text_index_clause = { kw_drop ~ kw_text ~ kw_index ~ identifier }

// --- CREATE/DROP ENCRYPTED INDEX (SSE, G017) ---

// CREATE ENCRYPTED INDEX idx_name ON :Label(property)
create_encrypted_index_clause = {
    kw_create ~ kw_encrypted ~ kw_index ~ identifier ~ kw_on ~ ":" ~ identifier ~ "(" ~ identifier ~ ")"
}

// DROP ENCRYPTED INDEX idx_name
drop_encrypted_index_clause = { kw_drop ~ kw_encrypted ~ kw_index ~ identifier }

// --- CREATE/DROP VECTOR INDEX ---

// CREATE VECTOR INDEX idx_name ON :Label(property) OPTIONS { m: 16, ef_construction: 200, metric: "cosine", dimensions: 128 }
create_vector_index_clause = {
    kw_create ~ kw_vector ~ kw_index ~ identifier ~ kw_on ~ ":" ~ identifier ~ "(" ~ identifier ~ ")"
    ~ (kw_options ~ vector_index_options)?
    ~ extension_tail?
}

// Vector index OPTIONS map: { key: value, ... }
vector_index_options = { "{" ~ vector_index_option ~ ("," ~ vector_index_option)* ~ ","? ~ "}" }
vector_index_option  = { identifier ~ ":" ~ (float_literal | integer_literal | string_literal) }

// Opaque trailing clause: any text after the engine-known CREATE VECTOR INDEX
// clauses, captured verbatim (atomic, so internal whitespace is preserved) for
// an extension handler to parse. The base engine registers no handler, so a
// non-empty tail surfaces as an unsupported-extension error at execution.
extension_tail = @{ (!EOI ~ ANY)+ }

// DROP VECTOR INDEX idx_name
drop_vector_index_clause = { kw_drop ~ kw_vector ~ kw_index ~ identifier }

// --- CREATE/DROP BTREE INDEX ---

// CREATE [UNIQUE] [SPARSE] INDEX idx_name ON :Label(prop) [WHERE pred]
create_index_clause = {
    kw_create ~ kw_unique? ~ kw_sparse? ~ kw_index ~ identifier ~ kw_on ~ ":" ~ identifier ~ "(" ~ identifier ~ ")"
    ~ where_inline?
}

// DROP INDEX idx_name
drop_index_clause = { kw_drop ~ kw_index ~ identifier }

// --- CREATE EDGE TYPE ---

// CREATE EDGE TYPE <name> [TEMPORAL] [WITH ( <property_decl_list> )]
//
// TEMPORAL marks the edge type as bitemporal: every instance carries
// (valid_from, valid_to) fields and multiple versions can coexist for the
// same (source, target) pair. WITH (...) declares user-defined edge
// properties.
create_edge_type_clause = {
    kw_create ~ kw_edge ~ kw_type ~ identifier ~ kw_temporal?
    ~ (kw_with ~ "(" ~ property_decl_list ~ ")")?
}

// --- CREATE NODE TYPE (R172a per ADR-027) ---
//
// CREATE NODE TYPE <name> [TEMPORAL] [WITH ( <property_decl_list> )]
//
// TEMPORAL marks the node label as bitemporal: every node record carries
// (valid_from, valid_to) fields and multiple versions can coexist per node_id.
// The valid-time axis (user-supplied) composes with the system-time axis
// (MVCC commit-timestamp + auto `__ingestion_ts__`) for full two-axis AS-OF
// queries. WITH (...) declares user-defined node properties. The TEMPORAL
// flag is immutable per label — toggling on an existing label is rejected
// at DDL time; re-creation via a new label is required.
create_node_type_clause = {
    kw_create ~ kw_node ~ kw_type ~ identifier ~ kw_temporal?
    ~ (kw_with ~ "(" ~ property_decl_list ~ ")")?
}

property_decl_list = { property_decl ~ ("," ~ property_decl)* ~ ","? }
property_decl      = { identifier ~ ":" ~ property_type_name ~ property_decl_modifier* }

property_type_name = @{
    ( ^"string" | ^"int" | ^"float" | ^"bool" | ^"timestamp"
    | ^"blob" | ^"map" | ^"geo" | ^"binary" | ^"document" )
    ~ !(ASCII_ALPHANUMERIC | "_")
}

property_decl_modifier = { kw_not ~ kw_null }

// --- TRIGGER DDL (R190 — per ADR-026) ---
//
//   CREATE TRIGGER name
//     ON :Label CREATE | UPDATE | DELETE              (or [:EdgeType])
//     BEFORE COMMIT | AFTER COMMIT
//     EXECUTE <clauses>
//     [MAXDEPTH n]
//     [ON ERROR PROPAGATE | RETRY n [WITH BACKOFF ms] | DEAD_LETTER]
//
// The EXECUTE body is one or more clauses; the body is terminated by either
// MAXDEPTH, ON ERROR, or the end of the query. Negative lookahead in
// `trigger_body_clause` keeps the chain from swallowing those terminators.

create_trigger_clause = {
    kw_create ~ kw_trigger ~ identifier
    ~ kw_on ~ trigger_target ~ trigger_event_list
    ~ trigger_timing ~ kw_commit
    ~ kw_execute ~ trigger_body
    ~ trigger_option*
}

// CASCADE_LIMIT / CASCADE_FANOUT / MAXDEPTH (deprecated alias) / ON ERROR
// — order-independent option list parsed after the body. See ADR-026A.
trigger_option = {
    trigger_cascade_limit
  | trigger_cascade_fanout
  | trigger_maxdepth
  | on_error_clause
}

trigger_target = {
    label_list                    // :Label  (reuse existing rule)
  | "[" ~ ":" ~ identifier ~ "]"  // [:EdgeType]
}

trigger_event_list = { trigger_event ~ ("|" ~ trigger_event)* }
trigger_event = {
    kw_create
  | kw_update
  | kw_delete
}

trigger_timing = { kw_before | kw_after }

trigger_body = { trigger_body_clause+ }

trigger_body_clause = {
    !(kw_on ~ kw_error)
  ~ !kw_maxdepth
  ~ !kw_cascade_limit
  ~ !kw_cascade_fanout
  ~ (
        optional_match_clause
      | match_clause
      | where_clause
      | return_clause
      | with_clause
      | unwind_clause
      | create_clause
      | merge_all_clause
      | merge_nodes_clause
      | merge_clause
      | upsert_clause
      | detach_delete_clause
      | delete_clause
      | set_clause
      | remove_clause
    )
}

// CASCADE_LIMIT n — L1 cascade depth override (ADR-026A).
trigger_cascade_limit = { kw_cascade_limit ~ integer_literal }
// CASCADE_FANOUT n — L2 per-trigger fanout override (ADR-026A).
trigger_cascade_fanout = { kw_cascade_fanout ~ integer_literal }
// Deprecated: MAXDEPTH n — alias for CASCADE_LIMIT n.
trigger_maxdepth = { kw_maxdepth ~ integer_literal }

on_error_clause = {
    kw_on ~ kw_error ~ (
        on_error_propagate
      | on_error_retry
      | on_error_dead_letter
    )
}

on_error_propagate   = { kw_propagate }
on_error_retry       = { kw_retry ~ integer_literal ~ (kw_with ~ kw_backoff ~ integer_literal)? }
on_error_dead_letter = { kw_dead_letter }

drop_trigger_clause   = { kw_drop ~ kw_trigger ~ identifier }
show_triggers_clause  = { kw_show ~ kw_triggers }

alter_trigger_clause = {
    kw_alter ~ kw_trigger ~ identifier ~ (
        alter_trigger_disable
      | alter_trigger_enable
      | alter_trigger_set_body
      | alter_trigger_set_on_error
    )
}
alter_trigger_disable       = { kw_disable }
alter_trigger_enable        = { kw_enable }
alter_trigger_set_body      = { kw_set ~ kw_execute ~ trigger_body }
alter_trigger_set_on_error  = { kw_set ~ on_error_clause }

// --- CREATE LABEL ---

// --- CREATE ---

create_clause = { kw_create ~ pattern_list }

// --- FOREACH ---
// FOREACH (x IN list | <update clauses>) — runs the inner update clauses once
// per element of `list`, with `x` bound. Only updating clauses are permitted
// inside (plus nested FOREACH); no MATCH/RETURN/WITH.
foreach_clause = { kw_foreach ~ "(" ~ identifier ~ kw_in ~ expression ~ "|" ~ foreach_update_clause+ ~ ")" }
foreach_update_clause = {
    create_clause
  | merge_all_clause
  | merge_nodes_clause
  | merge_clause
  | detach_delete_clause
  | delete_clause
  | set_clause
  | remove_clause
  | foreach_clause
}

// --- MERGE ---

merge_clause = { kw_merge ~ pattern ~ merge_action* }
merge_action = { on_match_action | on_create_action }
on_match_action  = { kw_on ~ kw_match ~ kw_set ~ set_items }
on_create_action = { kw_on ~ kw_create ~ kw_set ~ set_items }

// --- MERGE ALL (CoordiNode extension: Cartesian-product relationship merge) ---

merge_all_clause = { kw_merge ~ kw_all ~ pattern ~ merge_action* }

// --- MERGE NODES (R180: native node merge, replaces APOC apoc.refactor.mergeNodes) ---
//
//   MERGE NODES (a, b) INTO a
//     [ON CONFLICT KEEP FIRST | KEEP LAST | COALESCE | SET <set_items>]
//     [TRANSFER EDGES FROM <src> TO <dst>]
//     [ON DUPLICATE KEEP BOTH | MERGE PROPERTIES | KEEP TARGET]
//     [TRANSFER EDGE PROPERTIES]
//
// Semantic validation in parser (not grammar):
//   - INTO target ∈ {a, b}
//   - TRANSFER EDGES: dst == target, src ∈ {a, b} \ {target}
//   - ON DUPLICATE requires TRANSFER EDGES present
merge_nodes_clause = {
    kw_merge ~ kw_nodes ~ "(" ~ identifier ~ "," ~ identifier ~ ")"
    ~ kw_into ~ identifier
    ~ merge_nodes_option*
}

merge_nodes_option = {
    merge_nodes_on_conflict
  | merge_nodes_transfer_edges
  | merge_nodes_on_duplicate
  | merge_nodes_transfer_edge_props
}

merge_nodes_on_conflict = {
    kw_on ~ kw_conflict ~ ( mn_strategy_keep_first
                          | mn_strategy_keep_last
                          | mn_strategy_coalesce
                          | mn_strategy_set )
}
mn_strategy_keep_first = { kw_keep ~ kw_first }
mn_strategy_keep_last  = { kw_keep ~ kw_last }
mn_strategy_coalesce   = { kw_coalesce }
mn_strategy_set        = { kw_set ~ set_items }

merge_nodes_transfer_edges = {
    kw_transfer ~ kw_edges ~ kw_from ~ identifier ~ kw_to ~ identifier
}

merge_nodes_on_duplicate = {
    kw_on ~ kw_duplicate ~ ( mn_dup_keep_both
                           | mn_dup_merge_properties
                           | mn_dup_keep_target )
}
mn_dup_keep_both        = { kw_keep ~ kw_both }
mn_dup_merge_properties = { kw_merge ~ kw_properties }
mn_dup_keep_target      = { kw_keep ~ kw_target }

merge_nodes_transfer_edge_props = { kw_transfer ~ kw_edge ~ kw_properties }

// --- UPSERT MATCH (CoordiNode extension) ---

upsert_clause = { kw_upsert ~ kw_match ~ pattern ~ upsert_action* }
upsert_action = { upsert_on_match | upsert_on_create }
upsert_on_match  = { kw_on ~ kw_match ~ kw_set ~ set_items }
upsert_on_create = { kw_on ~ kw_create ~ kw_create ~ pattern_list }

// --- DELETE ---

detach_delete_clause = { kw_detach ~ kw_delete ~ expression_list }

// --- DETACH DOCUMENT (promote nested DOCUMENT property to graph node) ---
//
//   DETACH DOCUMENT n.address AS (a:Address)-[:HAS_ADDRESS]->(n)
//     [TRANSFER EDGES ON n TO a WHERE type(r) IN ['SHIPS_TO']]
//
// The AS target reuses the standard relationship pattern syntax.
detach_document_clause = {
    kw_detach ~ kw_document ~ detach_doc_source
    ~ kw_as ~ detach_doc_target ~ detach_doc_transfer?
}

// Source path: identifier "." identifier ("." identifier)*  (e.g. n.address, n.a.b)
detach_doc_source = { identifier ~ ("." ~ identifier)+ }

// Target: (a:Label)-[:TYPE]->(n) or (n)<-[:TYPE]-(a) (mirror form)
// One relationship between two node patterns.
detach_doc_target = { node_pattern ~ relationship_pattern ~ node_pattern }

// TRANSFER EDGES ON <src_var> TO <dst_var> WHERE <predicate>
detach_doc_transfer = {
    kw_transfer ~ kw_edges ~ kw_on ~ identifier ~ kw_to ~ identifier ~ where_inline
}

// --- ATTACH DOCUMENT (demote graph node to nested DOCUMENT property) ---
//
//   ATTACH (a:Address)-[:HAS_ADDRESS]->(u:User) INTO u.address
//     [TRANSFER EDGES ON a TO u WHERE type(r) = 'SHIPS_TO']
//     [ON CONFLICT REPLACE]
//     [ON REMAINING FAIL]
//
attach_document_clause = {
    kw_attach ~ attach_doc_pattern ~ kw_into ~ attach_doc_target
    ~ attach_doc_option*
}

attach_doc_pattern = { node_pattern ~ relationship_pattern ~ node_pattern }

// Target path (where the promoted node becomes a nested DOCUMENT):
//   identifier "." identifier ("." identifier)*
attach_doc_target = { identifier ~ ("." ~ identifier)+ }

attach_doc_option = {
    attach_doc_transfer
  | attach_doc_on_conflict
  | attach_doc_on_remaining
}

attach_doc_transfer = {
    kw_transfer ~ kw_edges ~ kw_on ~ identifier ~ kw_to ~ identifier ~ where_inline
}

attach_doc_on_conflict = { kw_on ~ kw_conflict ~ kw_replace }
attach_doc_on_remaining = { kw_on ~ kw_remaining ~ kw_fail }
delete_clause = { kw_delete ~ expression_list }
expression_list = { expression ~ ("," ~ expression)* }

// --- SET ---

set_clause = { kw_set ~ set_items ~ on_violation_skip? }
on_violation_skip = { kw_on ~ kw_violation ~ kw_skip }
set_items  = { set_item ~ ("," ~ set_item)* }

set_item = {
    set_doc_function
  | set_property_item
  | set_merge_props_item
  | set_replace_props_item
  | set_label_item
}

set_doc_function = {
    doc_function_name ~ "(" ~ property_or_variable ~ "," ~ expression ~ ")"
}
doc_function_name = { "doc_push" | "doc_pull" | "doc_add_to_set" | "doc_inc" }

set_property_item     = { identifier ~ ("." ~ identifier)+ ~ "=" ~ expression }
set_merge_props_item  = { identifier ~ "+=" ~ expression }
set_replace_props_item = { identifier ~ "=" ~ expression }
set_label_item        = { identifier ~ label_list }

// --- REMOVE ---

remove_clause = { kw_remove ~ remove_items }
remove_items  = { remove_item ~ ("," ~ remove_item)* }

remove_item = {
    remove_property_item
  | remove_label_item
}

remove_property_item = { identifier ~ ("." ~ identifier)+ }
remove_label_item    = { identifier ~ label_list }

// --- Property map ---

property_map = { "{" ~ property_pair ~ ("," ~ property_pair)* ~ "}" | "{" ~ "}" }
property_pair = { identifier ~ ":" ~ expression }

// --- Expressions ---

expression = { or_expr }

or_expr  = { xor_expr ~ (kw_or ~ xor_expr)* }
xor_expr = { and_expr ~ (kw_xor ~ and_expr)* }
and_expr = { not_expr ~ (kw_and ~ not_expr)* }

not_expr = { kw_not ~ not_expr | comparison }

comparison = { addition ~ comparison_tail? }

comparison_tail = {
    regex_op ~ addition
  | comp_op ~ addition
  | is_typed_op
  | is_not_null_op
  | is_null_op
  | in_op ~ addition
  | starts_with_op ~ addition
  | ends_with_op ~ addition
  | contains_op ~ addition
}

is_not_null_op  = { kw_is ~ kw_not ~ kw_null }
is_null_op      = { kw_is ~ kw_null }
// `IS :: TYPE` / `IS NOT :: TYPE` type predicate. type_name is a single base
// type keyword (INTEGER, FLOAT, STRING, BOOLEAN, LIST, MAP, NULL, …).
is_typed_op     = { kw_is ~ kw_not? ~ "::" ~ type_name }
type_name       = @{ (ASCII_ALPHANUMERIC | "_")+ }
in_op           = { kw_in }
starts_with_op  = { kw_starts ~ kw_with }
ends_with_op    = { kw_ends ~ kw_with }
contains_op     = { kw_contains }
regex_op        = { "=~" }

comp_op = { "<>" | "<=" | ">=" | "=" | "<" | ">" }

addition = { multiplication ~ ((add_op) ~ multiplication)* }
add_op   = { "+" | "-" }

multiplication = { unary ~ ((mul_op) ~ unary)* }
mul_op         = { "*" | "/" | "%" }

unary = { "-" ~ unary | postfix }

// postfix: atom optionally followed by one or more subscript accesses: expr[index]
// Supports: labels(n)[0], list[i], map["key"], nested[0][1], etc.
postfix = { atom ~ index_access* }
// Either a single-element index `[i]` or a slice `[s..e]` (both bounds
// optional). `list_slice` is tried first; it needs a `..`, so a plain `[i]`
// falls through to `expression`.
index_access = { "[" ~ (list_slice | expression) ~ "]" }
list_slice = { slice_start? ~ ".." ~ slice_end? }
slice_start = { expression }
slice_end = { expression }

atom = {
    exists_subquery
  | count_subquery
  | collect_subquery
  | reduce_expr
  | list_predicate
  | list_comprehension
  | pattern_comprehension
  | function_call
  | case_expr
  | list_literal
  | map_projection
  | map_literal
  | parameter
  | string_literal
  | float_literal
  | integer_literal
  | boolean_literal
  | null_literal
  | pattern_predicate
  | property_or_variable
  | "(" ~ expression ~ ")"
}

// Pattern predicate in expression context: `(a)-[:R]->(b)` evaluates to boolean.
// Must contain at least one relationship (otherwise it's just a parenthesized expression).
pattern_predicate = { node_pattern ~ (relationship_pattern ~ node_pattern)+ }

// --- Atoms ---

property_or_variable = { identifier ~ ("." ~ identifier)* }

function_call = { function_name ~ "(" ~ distinct_kw? ~ function_args? ~ ")" }
function_name = { identifier ~ ("." ~ identifier)* }
function_args = { star | expression ~ ("," ~ expression)* }

// EXISTS { MATCH … [WHERE …] } — existential subquery; true if the inner
// MATCH yields at least one row (correlated with outer-scope bindings).
exists_subquery = { kw_exists ~ "{" ~ match_clause ~ "}" }

// COUNT { MATCH … [WHERE …] } — counts the rows the inner MATCH yields
// (correlated with outer bindings). COLLECT { MATCH … RETURN expr } — gathers
// `expr` over each matching row into a list. The `{` after the keyword
// disambiguates from the `count(...)` / `collect(...)` aggregate functions, so
// these keywords are NOT reserved.
count_subquery = { kw_count ~ "{" ~ match_clause ~ "}" }
collect_subquery = { kw_collect ~ "{" ~ match_clause ~ kw_return ~ expression ~ "}" }

// [(a)-[:R]->(b) WHERE pred | expr] — pattern comprehension. The mandatory
// `| expr` distinguishes it from a list literal; placed after list_comprehension
// in `atom` (which starts with `[` identifier IN). `pattern` is the same rule a
// MATCH uses, so semantics match MATCH exactly.
pattern_comprehension = {
    "[" ~ pattern ~ (kw_where ~ expression)? ~ "|" ~ expression ~ "]"
}

// [x IN list WHERE pred | expr] — list comprehension; WHERE and `| expr` both
// optional. Must precede list_literal in `atom` (both open with `[`); the
// `identifier ~ kw_in` prefix disambiguates from a plain list.
list_comprehension = {
    "[" ~ identifier ~ kw_in ~ expression ~ (kw_where ~ expression)? ~ ("|" ~ expression)? ~ "]"
}

// all/any/none/single(x IN list WHERE pred) — list quantifier predicates.
list_predicate = {
    list_quantifier ~ "(" ~ identifier ~ kw_in ~ expression ~ kw_where ~ expression ~ ")"
}
list_quantifier = { kw_all | kw_any | kw_none | kw_single }

// reduce(acc = init, x IN list | expr) — left fold over a list.
reduce_expr = {
    kw_reduce ~ "(" ~ identifier ~ "=" ~ expression ~ "," ~ identifier ~ kw_in ~ expression
    ~ "|" ~ expression ~ ")"
}

case_expr = {
    kw_case ~ expression? ~ when_clause+ ~ else_clause? ~ kw_end
}
when_clause = { kw_when ~ expression ~ kw_then ~ expression }
else_clause = { kw_else ~ expression }

list_literal = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }

map_literal = { "{" ~ (map_pair ~ ("," ~ map_pair)*)? ~ "}" }
map_pair    = { identifier ~ ":" ~ expression }

map_projection      = { property_or_variable ~ "{" ~ map_projection_item ~ ("," ~ map_projection_item)* ~ "}" }
map_projection_item = { map_projection_shorthand | map_projection_computed }
map_projection_shorthand = { "." ~ identifier }
map_projection_computed  = { identifier ~ ":" ~ expression }

parameter = { "$" ~ identifier }

// --- Literals ---

null_literal    = { kw_null }
boolean_literal = { kw_true | kw_false }

float_literal   = @{
    ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ ~ (("e" | "E") ~ ("+" | "-")? ~ ASCII_DIGIT+)?
  | ASCII_DIGIT+ ~ ("e" | "E") ~ ("+" | "-")? ~ ASCII_DIGIT+
}

integer_literal = @{ ASCII_DIGIT+ }

// Compound-atomic ($): no implicit WHITESPACE between the quotes and the
// content, so leading/trailing/whitespace-only string literals (e.g. ' ' or
// '  hi ') keep their spaces. Inner content rules still emit tokens for the
// builder. A plain `{ ... }` rule lets pest insert optional WHITESPACE at each
// `~`, which silently strips edge whitespace from string literals.
string_literal = ${
    "'" ~ single_string_content ~ "'"
  | "\"" ~ double_string_content ~ "\""
}
single_string_content = @{ (!"'" ~ ("\\\\" | "\\'" | ANY))* }
double_string_content = @{ (!"\"" ~ ("\\\\" | "\\\"" | ANY))* }

// --- Keywords (case-insensitive) ---
// Separated rules to avoid PEG matching issues with multi-word constructs.

kw_match      = @{ ^"match" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_shortestpath = @{ ^"shortestpath" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_optional   = @{ ^"optional" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_where      = @{ ^"where" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_return     = @{ ^"return" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_with       = @{ ^"with" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_unwind     = @{ ^"unwind" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_as         = @{ ^"as" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_order      = @{ ^"order" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_by         = @{ ^"by" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_skip       = @{ ^"skip" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_limit      = @{ ^"limit" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_distinct   = @{ ^"distinct" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_and        = @{ ^"and" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_or         = @{ ^"or" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_xor        = @{ ^"xor" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_not        = @{ ^"not" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_in         = @{ ^"in" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_is         = @{ ^"is" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_null       = @{ ^"null" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_true       = @{ ^"true" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_false      = @{ ^"false" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_starts     = @{ ^"starts" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_ends       = @{ ^"ends" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_contains   = @{ ^"contains" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_asc        = @{ ^"asc" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_ascending  = @{ ^"ascending" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_desc       = @{ ^"desc" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_descending = @{ ^"descending" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_of         = @{ ^"of" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_timestamp  = @{ ^"timestamp" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_case       = @{ ^"case" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_reduce     = @{ ^"reduce" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_when       = @{ ^"when" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_then       = @{ ^"then" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_else       = @{ ^"else" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_end        = @{ ^"end" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_create     = @{ ^"create" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_merge      = @{ ^"merge" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_all        = @{ ^"all" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_union      = @{ ^"union" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_foreach    = @{ ^"foreach" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_any        = @{ ^"any" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_none       = @{ ^"none" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_single     = @{ ^"single" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_exists     = @{ ^"exists" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_count      = @{ ^"count" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_collect    = @{ ^"collect" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_delete     = @{ ^"delete" ~ !(ASCII_ALPHANUMERIC | "_") }
