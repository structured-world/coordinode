kw_show        = @{ ^"show" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_enable      = @{ ^"enable" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_disable     = @{ ^"disable" ~ !(ASCII_ALPHANUMERIC | "_") }

// --- Identifiers ---

variable   = { identifier }
identifier = @{
    !reserved_word ~ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")*
  | "`" ~ (!"`" ~ ANY)+ ~ "`"
}

reserved_word = @{
    ( ^"match" | ^"optional" | ^"where" | ^"return" | ^"with"
    | ^"unwind" | ^"order" | ^"skip" | ^"limit" | ^"as"
    | ^"and" | ^"or" | ^"xor" | ^"not" | ^"in"
    | ^"null" | ^"true" | ^"false" | ^"is"
    | ^"starts" | ^"ends" | ^"contains"
    | ^"distinct" | ^"by" | ^"asc" | ^"ascending"
    | ^"desc" | ^"descending" | ^"of" | ^"timestamp"
    | ^"case" | ^"when" | ^"then" | ^"else" | ^"end"
    | ^"create" | ^"merge" | ^"delete" | ^"detach" | ^"set" | ^"remove"
    | ^"on" | ^"upsert" | ^"call" | ^"yield"
    | ^"alter" | ^"label" | ^"schema"
    | ^"union" | ^"foreach"
    ) ~ !(ASCII_ALPHANUMERIC | "_")
}
