kw_type       = @{ ^"type" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_temporal   = @{ ^"temporal" ~ !(ASCII_ALPHANUMERIC | "_") }
// CREATE NODE TYPE — bitemporal node-label DDL (R172a per ADR-027).
// Context keyword: `node` remains a valid identifier elsewhere.
kw_node       = @{ ^"node" ~ !(ASCII_ALPHANUMERIC | "_") }
// MERGE NODES (R180) — context keywords (NOT in reserved_word, so they remain
// valid identifiers and function names like coalesce()).
kw_nodes      = @{ ^"nodes" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_from       = @{ ^"from" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_keep       = @{ ^"keep" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_first      = @{ ^"first" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_last       = @{ ^"last" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_coalesce   = @{ ^"coalesce" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_both       = @{ ^"both" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_target     = @{ ^"target" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_properties = @{ ^"properties" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_duplicate  = @{ ^"duplicate" ~ !(ASCII_ALPHANUMERIC | "_") }
// TRIGGER DDL (R190) — context keywords (NOT in reserved_word, so they
// remain valid identifiers in user data).
kw_trigger     = @{ ^"trigger" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_triggers    = @{ ^"triggers" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_before      = @{ ^"before" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_after       = @{ ^"after" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_commit      = @{ ^"commit" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_execute     = @{ ^"execute" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_error       = @{ ^"error" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_propagate   = @{ ^"propagate" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_retry       = @{ ^"retry" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_backoff     = @{ ^"backoff" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_dead_letter = @{ ^"dead_letter" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_maxdepth        = @{ ^"maxdepth" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_cascade_limit   = @{ ^"cascade_limit" ~ !(ASCII_ALPHANUMERIC | "_") }
