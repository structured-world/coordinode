kw_attach     = @{ ^"attach" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_into       = @{ ^"into" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_conflict   = @{ ^"conflict" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_replace    = @{ ^"replace" ~ !(ASCII_ALPHANUMERIC | "_") }
kw_remaining  = @{ ^"remaining" ~ !(ASCII_ALPHANUMERIC | "_") }
