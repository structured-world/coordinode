# Bench results JSON files DO live in the repo — committed by the
# CN bench CI job (push-to-main, self-hosted runner on
# gpu.private.systems) AND placed manually by the human after
# off-cycle competitor re-baselining. Track them with
# `git add bench-results/...` like any other file.
# The local `out/` Docker volume from
# benches/vector-ann/docker/compose.competitors.yml is gitignored:
benches/vector-ann/docker/out/

# Generated by yarn docs:build (scripts/build-bench-manifest.py)
docs/public/bench-data/
docs/public/bench-results/
